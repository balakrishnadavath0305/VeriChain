# Copy this file to .env and fill in your values
# DO NOT commit .env — it is gitignored

# Smart contract address on Polygon Amoy
VITE_CONTRACT_ADDRESS=0xYourContractAddressHere

# Your Render backend URL (use http://localhost:4000 locally)
VITE_BACKEND_URL=https://your-backend.onrender.com

# Network: "amoy" or "localhost"
VITE_PREFERRED_NETWORK=amoy

# NOTE: PINATA_JWT and GEMINI_API_KEY belong in the BACKEND .env (Render dashboard)
# Do NOT put them here — they would be exposed in the JS bundle.
