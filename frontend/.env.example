# Copy this file to .env and fill in your values
# DO NOT commit the .env file — it contains secrets

# Smart contract address deployed on Polygon Amoy
VITE_CONTRACT_ADDRESS=0xYourContractAddressHere

# Pinata JWT for IPFS file uploads (get from https://app.pinata.cloud)
VITE_PINATA_JWT=your_pinata_jwt_token_here

# Backend API URL — use your Render URL in production
VITE_BACKEND_URL=https://your-backend.onrender.com

# Preferred network: "amoy" for Polygon Amoy testnet, "localhost" for local Hardhat
VITE_PREFERRED_NETWORK=amoy

# Gemini API key for AI features (get from https://aistudio.google.com)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
